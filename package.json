{
  "name": "@algoux/standard-ranklist-cli",
  "version": "0.3.4",
  "description": "Command-line workflows for Standard Ranklist files.",
  "type": "module",
  "bin": {
    "srk": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && pnpm run build:template && node scripts/ensure-bin-executable.mjs",
    "build:template": "vite build --config vite.preview.config.ts && node scripts/embed-preview-template.mjs",
    "test": "pnpm run build:template && tsc --noEmit -p tsconfig.test.json && node --import tsx --test tests/*.test.ts",
    "test:release": "pnpm run build && pnpm run test && node tests/pack-smoke.mjs",
    "release:audit": "node scripts/audit-release-plan.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "release:prepare-publish": "pnpm run release:audit && pnpm run test:release",
    "changeset:publish": "pnpm run release:prepare-publish && changeset publish",
    "prepublishOnly": "pnpm run release:prepare-publish"
  },
  "keywords": [
    "standard ranklist",
    "srk",
    "cli"
  ],
  "author": "bLue",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoux/standard-ranklist-cli.git"
  },
  "bugs": {
    "url": "https://github.com/algoux/standard-ranklist-cli/issues"
  },
  "homepage": "https://github.com/algoux/standard-ranklist-cli#readme",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@algoux/standard-ranklist": "^0.3.13",
    "@algoux/standard-ranklist-utils": "^0.3.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@algoux/standard-ranklist-renderer-component-core": "0.6.2",
    "@algoux/standard-ranklist-renderer-component-styles": "0.6.1",
    "@algoux/standard-ranklist-renderer-component-svelte": "0.6.3",
    "@changesets/cli": "^2.31.0",
    "@sveltejs/vite-plugin-svelte": "1.0.0-next.49",
    "@types/node": "^22.15.3",
    "svelte": "3.59.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "2.9.12"
  },
  "packageManager": "pnpm@11.1.3"
}
